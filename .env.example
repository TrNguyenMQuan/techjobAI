# Base URL for the REST API (Tầng 1 & 2 — jobs, dashboard, market, profile)
VITE_API_URL=http://localhost:8000/api

# WebSocket endpoint for the AI Assistant streaming chat (Tầng 3 & 4)
VITE_WS_URL=ws://localhost:8000/ws/chat

# Set true only for UI-only demos without the backend.
VITE_USE_MOCK=false

# AI requests can take longer on the first model warm-up.
VITE_CHAT_TIMEOUT_MS=90000
