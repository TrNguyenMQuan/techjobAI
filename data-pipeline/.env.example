# MinIO 
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ── Airflow 
# Generate bằng: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

# PostgreSQL local fallback for Docker/dev.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=techjob_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
# SSL: local để trống; khi publish lên Neon (prod) set = require
POSTGRES_SSLMODE=

# NeonDB runtime DB for FastAPI/AI features.
# Set these on the backend server/container only. Frontend users never see
# these values; they only call VITE_API_URL -> FastAPI.
NEON_HOST=ep-xxx-xxx.ap-southeast-1.aws.neon.tech
NEON_PORT=5432
NEON_DB=neondb                 # hoặc tên DB bạn tạo
NEON_USER=your_readonly_or_service_user
NEON_PASSWORD=your_neon_password
NEON_SSLMODE=require

# Groq LLM
GROQ_API_KEY=your_primary_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: a second key/model used when the primary key reaches its quota.
# If omitted, fallback uses GROQ_API_KEY.
GROQ_FALLBACK_API_KEY=
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Provider routing: each provider is tried from left to right
LLM_PROVIDER_CHAIN=openrouter,mistral,cerebras,groq

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest

CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=gpt-oss-120b
